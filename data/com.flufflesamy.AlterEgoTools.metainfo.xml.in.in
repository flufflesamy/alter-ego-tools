<?xml version="1.0" encoding="UTF-8"?>
<!-- Amy Poon 2026 <amy@amypoon.me> -->
<component type="desktop-application">
  <id>@app-id@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Alter Ego Tools</name>
  <summary>Tools for Alter Ego moderators</summary>
  <description>
    <p>Alter Ego Tools provides a set of utilities to help moderators of Alter Ego, a text-based roleplaying game.</p>
    <ul>
      <li>Description Formatter — converts plain text into Alter Ego XML description markup</li>
      <li>Procedural Generator — creates procedural content tags with configurable stats and outcomes</li>
    </ul>
  </description>
  <screenshots>
    <screenshot type="default">
      <!-- TODO: Update URL to point to a specific release tag or commit once v0.1.0 is tagged -->
      <image>https://github.com/flufflesamy/alter-ego-tools/raw/v0.1.0/data/resources/screenshots/screenshot1.png</image>
      <caption>Main window</caption>
    </screenshot>
  </screenshots>
  <url type="homepage">https://github.com/flufflesamy/alter-ego-tools</url>
  <url type="bugtracker">https://github.com/flufflesamy/alter-ego-tools/issues</url>
  <url type="vcs-browser">https://github.com/flufflesamy/alter-ego-tools</url>
  <url type="translate">https://github.com/flufflesamy/alter-ego-tools/tree/main/po</url>
  <!-- Open Age Ratings Service:
       https://hughsie.github.io/oars/generate.html
  -->
  <content_rating type="oars-1.1"/>
  <releases>
    <!-- TODO: Update date to match the actual release date -->
    <release version="0.1.0" date="2026-01-01">
      <description>
        <p>Initial release.</p>
      </description>
    </release>
  </releases>
  <developer id="com.flufflesamy">
    <name translate="no">flufflesamy</name>
  </developer>
  <!--
    Branding colors:
    https://docs.flathub.org/docs/for-app-authors/metainfo-guidelines/#brand-color
    Preview: https://docs.flathub.org/banner-preview
    TODO: Replace placeholder colors with actual brand colors
  -->
  <branding>
    <color type="primary" scheme_preference="light">#ff00ff</color>
    <color type="primary" scheme_preference="dark">#993d3d</color>
  </branding>
  <update_contact>amy@amypoon.me</update_contact>
  <translation type="gettext">@gettext-package@</translation>
  <launchable type="desktop-id">@app-id@.desktop</launchable>
</component>
